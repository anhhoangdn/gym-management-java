# Copy this file to .env and update values for your local machine
# JDBC configuration (simple style like BTTHSo3)
DB_DRIVER=com.mysql.cj.jdbc.Driver
DB_URL=jdbc:mysql://localhost:3306/java-gym?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Ho_Chi_Minh
DB_USER=root
DB_PASSWORD=your_password_here

# SQL Server (Windows auth) example from BTTH style:
# DB_DRIVER=com.microsoft.sqlserver.jdbc.SQLServerDriver
# DB_URL=jdbc:sqlserver://localhost:1433;databaseName=JavaDB;encrypt=true;trustServerCertificate=true;integratedSecurity=true;
# DB_USER=
# DB_PASSWORD=
